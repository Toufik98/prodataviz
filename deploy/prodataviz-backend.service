[Unit]
Description=ProDataViz Backend (FastAPI/Uvicorn)
After=network.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/prodataviz/backend
Environment="PATH=/home/ubuntu/prodataviz/backend/.venv/bin:/usr/local/bin:/usr/bin"
ExecStart=/home/ubuntu/prodataviz/backend/.venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000 --workers 2
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
