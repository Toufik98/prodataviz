# --------------------------------------------------
# ProDataViz — Environment Variables
# Copy this file to .env and fill in the values.
# --------------------------------------------------

# Used at frontend build time — base path for API calls
NEXT_PUBLIC_API_URL=/projects/prodataviz

# Backend CORS origins (comma-separated)
CORS_ORIGINS=https://tferhat.com

# Docker image tag (for docker-compose.prod.yml)
TAG=latest
